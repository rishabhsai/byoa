    "test": "node --test protocol-guard.test.mjs"
  },
  "dependencies": {
    "@cloudflare/sandbox": "0.12.3"
  },
  "devDependencies": {
    "typescript": "^7.0.2",
    "wrangler": "4.112.0"
  }
}
