{
  "name": "@byoa/runner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "wrangler deploy --dry-run --containers-rollout=none --outdir dist",
    "build:container": "wrangler deploy --dry-run --outdir dist-container",
