{
  "name": "@rishabhsai/byoa",
  "version": "0.1.0",
  "description": "Run user-authorized Codex app-servers in your Cloudflare account",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "default": "./dist/react.js"
    }
  },
  "bin": {
    "byoa": "dist/cli.js"
  },
  "files": ["dist", "!dist/*.test.*"],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-runner.mjs",
    "check": "tsc -p tsconfig.json --noEmit",
    "prepack": "npm run build",
    "test": "node --test dist/*.test.js"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "react": "^19.2.7",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": ["codex", "cloudflare", "agent", "sdk"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rishabhsai/byoa.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://byoa.lol",
  "bugs": {
    "url": "https://github.com/rishabhsai/byoa/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0"
}
